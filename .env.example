# Copy to .env before running docker compose.
# Host port exposed by docker compose.
ID_DOC_OCR_PORT=8000

# Runtime options passed to the API process.
ID_DOC_OCR_HOST=0.0.0.0
ID_DOC_OCR_API_PORT=8000
ID_DOC_OCR_LOG_LEVEL=info

# Directory mounted into the container for failed samples / diagnostics.
ID_DOC_OCR_FAILURE_DIR=./data/failures
